PORT=5000
MONGODB_URI=mongodb://localhost:27017/expense-tracker
JWT_SECRET=your_super_secret_key_here
NODE_ENV=development

# Firebase: Either place serviceAccountKey.json in the backend/ directory (local)
# OR set FIREBASE_SERVICE_ACCOUNT environment variable with the ENTIRE JSON content (Render/Production)
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'
